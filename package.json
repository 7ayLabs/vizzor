{
  "name": "@vizzor/cli",
  "version": "0.12.0",
  "description": "AI-powered crypto chronovisor — on-chain intelligence for the future",
  "type": "module",
  "license": "BUSL-1.1",
  "author": "7ayLabs <dev@7aylabs.com>",
  "homepage": "https://vizzor.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/7ayLabs/vizzor.git"
  },
  "bugs": {
    "url": "https://github.com/7ayLabs/vizzor/issues"
  },
  "bin": {
    "vizzor": "./dist/index.js"
  },
  "files": [
    "dist/",
    "LICENSE.md",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "VIZZOR_INTEGRATION=true vitest run test/integration/",
    "clean": "rm -rf dist/",
    "prepare": "husky || true",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "crypto",
    "blockchain",
    "ai",
    "cli",
    "ethereum",
    "defi",
    "web3",
    "analysis",
    "chronovisor",
    "7aylabs"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.0.1",
    "@google/generative-ai": "^0.24.1",
    "@scure/bip32": "1.6.2",
    "@scure/bip39": "1.5.4",
    "@types/react": "^19.2.14",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "discord.js": "^14.25.1",
    "fastify": "^5.8.2",
    "grammy": "^1.41.1",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^13.3.0",
    "marked": "^17.0.4",
    "marked-terminal": "^7.3.0",
    "node-notifier": "^10.0.1",
    "ollama": "^0.6.3",
    "openai": "^6.27.0",
    "ora": "^9.3.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rate-limiter-flexible": "^10.0.1",
    "react": "^19.2.4",
    "viem": "^2.47.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "undici": ">=6.24.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "@types/node-notifier": "^8.0.5",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  }
}
